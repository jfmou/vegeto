{
  "name": "vegeto",
  "version": "0.0.1",
  "description": "11ty powered vegeto website",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf ./dist/ && mkdir -p ./dist/assets/generated",
    "build": "npm run clean && npx eleventy",
    "build:beta": "ELEVENTY_NO_INDEX=true ELEVENTY_BUILD_TARGET=beta npm run build && mv ./dist/ ./beta/",
    "build-assets": "cp -a ./src/assets ./dist/",
    "dev": "npx tinacms dev -c \"npx eleventy --serve\"",
    "debug": "DEBUG=* npx eleventy",
    "sync-content": "bash ./scripts/sync-content.sh",
    "save": "bash ./scripts/save-content.sh",
    "publish": "bash ./scripts/publish-content.sh",
    "cleanup": "bash ./scripts/cleanup-merged-content-branches.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfmou/vegeto.git"
  },
  "author": "jeff",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jfmou/vegeto/issues"
  },
  "homepage": "https://github.com/jfmou/vegeto#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@codestitchofficial/eleventy-plugin-minify": "^1.1.3"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.1.11",
    "tinacms": "^3.6.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
