---
layout: layouts/base
---

<div class="container">
  <div class="content static-page helio-page">
    <div class="static-page-intro static-page-intro--helio">
      <div class="helio-intro-copy">
        <h1>{{ title }}</h1>
        {% if lead %}<p>{{ lead }}</p>{% endif %}
      </div>
      <img class="helio-logo" src="/assets/logo-helio.webp" alt="Logo Hélio" loading="lazy" decoding="async">
    </div>
    <div class="static-page-body">
      {% if heroImage %}
        {% assign helioHeroAlt = heroImageAlt %}
        {% if helioHeroAlt == nil or helioHeroAlt == '' %}{% assign helioHeroAlt = title %}{% endif %}
        <p class="helio-main-image">{% image heroImage, helioHeroAlt %}</p>
      {% endif %}
      {{ content }}
    </div>
  </div>

  {% assign has_testimonial_content = false %}
  {% if testimonial %}
    {% if testimonial.quote != blank %}
      {% assign has_testimonial_content = true %}
    {% endif %}
    {% if testimonial.author != blank %}
      {% assign has_testimonial_content = true %}
    {% endif %}
    {% if testimonial.role != blank %}
      {% assign has_testimonial_content = true %}
    {% endif %}
    {% if testimonial.image != blank %}
      {% assign has_testimonial_content = true %}
    {% endif %}
  {% endif %}

  {% if has_testimonial_content %}
    <div class="realisation-testimonial realisation-testimonial--no-cta">
      <div class="testimonial-content">
        {% if testimonial.image != blank %}
          <div class="testimonial-avatar">
            {% image testimonial.image, testimonial.author, 200, "200px" %}
          </div>
        {% endif %}
        <div>
          {% if testimonial.quote != blank %}<blockquote class="testimonial-quote">{{ testimonial.quote }}</blockquote>{% endif %}
          <div class="testimonial-author">
            <div class="testimonial-info">
              {% if testimonial.author != blank %}<p class="testimonial-name">{{ testimonial.author }}</p>{% endif %}
              {% if testimonial.role %}<p class="testimonial-role">{{ testimonial.role }}</p>{% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
