<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <title>{{ title }} | Végéto₂ l'aquaponie sur-mesure</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="rgb(185, 198, 189)">
    <meta name="msapplication-navbutton-color" content="rgb(185, 198, 189)">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1">
    
    <!-- Dynamic description based on page type -->
    {% if seoDescription %}
      {% assign description = seoDescription %}
    {% elsif page.url == '/' %}
      {% assign description = "Entreprise spécialisée dans l'Aquaponie, située entre Soissons et Compiègne. Formations, études, réalisations et installations de kits sur-mesure pour professionels et particuliers." %}
    {% elsif page.url == '/realisations/' %}
      {% assign description = "Découvrez nos réalisations en aquaponie : conception, installation et transmission de projets sur-mesure pour professionnels, collectivités et particuliers." %}
    {% elsif page.filePathStem contains '/realisations/' %}
      {% assign description = "Découvrez notre accompagnement en aquaponie avec " | append: title %}
      {% if location %}
        {% assign description = description | append: " à " | append: location %}
      {% endif %}
      {% assign description = description | append: "." %}
    {% else %}
      {% assign description = "Entreprise spécialisée dans l'Aquaponie, située entre Soissons et Compiègne. Formations, études, réalisations et installations de kits sur-mesure pour professionels et particuliers." %}
    {% endif %}
    <meta name="description" content="{{ description }}">
    {% if noIndex %}
      <meta name="robots" content="noindex, nofollow">
      <meta name="googlebot" content="noindex, nofollow">
    {% endif %}
    
    <!-- Facebook OpenGraph Data -->
    <meta property="og:title" content="{{ title }} | Vegeto Aquaponie">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ siteUrl }}{{ page.url }}">
    <meta property="og:description" content="{{ description }}">
    
    {% assign socialImageUrl = socialImage | default: '/assets/logo-og.png' %}
    <meta property="og:image" content="{{ siteUrl }}{{ socialImageUrl }}">
    
    <!-- Twitter Card Data -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | Vegeto Aquaponie">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ siteUrl }}{{ socialImageUrl }}">
    
    <link rel="stylesheet" href="/assets/generated/style.css">
    <link rel="stylesheet" href="/assets/generated/fonts.css">
    <link
      rel="icon"
      type="image/png"
      href="/assets/favicon.png" />
    <link rel="canonical" href="{{ siteUrl }}{{ page.url }}" />
  </head>
  <body>

    {% include header %}

    <main class="main" role="main">
      {{ content }}
    </main>

    {% include footer %}

  </body>
</html>