---
layout: layouts/base
---

<div class="container">
  <div class="content">
    {% assign realisation_type = '' %}
    {% if tags %}
      {% for tag in tags %}
        {% if tag != "realisation" and realisation_type == '' %}
          {% assign realisation_type = tag %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% assign heading_visual_label = 'Co' %}
    {% if realisation_type == 'installation' %}
      {% assign heading_visual_label = 'In' %}
    {% elsif realisation_type == 'transmission' %}
      {% assign heading_visual_label = 'Tr' %}
    {% endif %}

    <div class="realisation-header{% if realisation_type != '' %} realisation-header--{{ realisation_type }}{% endif %}">
      <div class="realisation-heading">
        <div class="realisation-heading-copy">
          <h1>{{ title }}</h1>
          {% if location %}<p class="realisation-location">{{ location }}</p>{% endif %}
          {% if tags %}
            <p class="realisation-tags">
              {% for tag in tags %}
                {% if tag != "realisation" %}{{ tag }}{% endif %}
              {% endfor %}
            </p>
          {% endif %}
        </div>
        <span class="realisation-heading-visual" aria-hidden="true">{{ heading_visual_label }}</span>
      </div>
    </div>

    {% if mainImg %}
      <div class="realisation-main-image">
        {% image mainImg, title %}
      </div>
    {% endif %}

    <div class="realisation-body">
      {{ content }}
    </div>

    {% if cta %}
      <div class="realisation-cta">
        <a href="{{ cta.link }}" class="cta-button" target="_blank" title="Découvrir {{ cta.text }}">
          <span class="btn-top">EN SAVOIR PLUS SUR</span>
          <span class="btn-bottom">{{ title }}</span>
        </a>
      </div>
    {% endif %}
  </div>

  {% if testimonial %}
    <div class="realisation-testimonial{% if cta %} realisation-testimonial--with-cta{% else %} realisation-testimonial--no-cta{% endif %}">
      <div class="testimonial-content">
        {% if testimonial.image %}
          <div class="testimonial-avatar">
            {% image testimonial.image, testimonial.author, 200, "200px" %}
          </div>
        {% endif %}
        <div>
          <blockquote class="testimonial-quote">{{ testimonial.quote }}</blockquote>
          <div class="testimonial-author">
            <div class="testimonial-info">
              <p class="testimonial-name">{{ testimonial.author }}</p>
              {% if testimonial.role %}<p class="testimonial-role">{{ testimonial.role }}</p>{% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="content">
    <!-- Footer navigation: previous / index / next -->
    <div class="realisation-footer-buttons">
      {% assign orderedItems = collections.realisation | sort: "date" | reverse %}
      {% assign urlsConcat = '' %}
      {% assign titlesConcat = '' %}
      {% assign total = 0 %}
      {% assign currentIndex = -1 %}

      {% for item in orderedItems %}
        {% if item.data.draft == false or item.data.draft == nil %}
          {% if urlsConcat == '' %}
            {% assign urlsConcat = item.url %}
            {% assign titlesConcat = item.data.title %}
          {% else %}
            {% assign urlsConcat = urlsConcat | append: '||' | append: item.url %}
            {% assign titlesConcat = titlesConcat | append: '||' | append: item.data.title %}
          {% endif %}

          {% if item.url == page.url %}
            {% assign currentIndex = total %}
          {% endif %}

          {% assign total = total | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% assign urls = urlsConcat | split: '||' %}
      {% assign titles = titlesConcat | split: '||' %}

      {% assign prevIndex = currentIndex | minus: 1 %}
      {% if prevIndex < 0 %}
        {% assign prevIndex = total | minus: 1 %}
      {% endif %}

      {% assign nextIndex = currentIndex | plus: 1 %}
      {% if nextIndex >= total %}
        {% assign nextIndex = 0 %}
      {% endif %}

      {% assign prevUrl = urls[prevIndex] %}
      {% assign prevTitle = titles[prevIndex] %}
      {% assign nextUrl = urls[nextIndex] %}
      {% assign nextTitle = titles[nextIndex] %}

      {% if total > 1 and currentIndex >= 0 and prevUrl != blank %}
      <a href="{{ prevUrl }}" class="cta-button cta-small" title="Voir : {{ prevTitle }}">
        <span class="btn-top">RÉALISATION</span>
        <span class="btn-bottom">PRÉCÉDENTE</span>
      </a>
      {% else %}
      <span class="cta-button cta-small" aria-hidden="true">
        <span class="btn-top">RÉALISATION</span>
        <span class="btn-bottom">PRÉCÉDENTE</span>
      </span>
      {% endif %}
      <a href="/realisations/" class="cta-button cta-small" title="Retour à la liste des réalisations">
        <span class="btn-top">TOUTES LES</span>
        <span class="btn-bottom">RÉALISATIONS</span>
      </a>
      {% if total > 1 and currentIndex >= 0 and nextUrl != blank %}
      <a href="{{ nextUrl }}" class="cta-button cta-small" title="Voir : {{ nextTitle }}">
        <span class="btn-top">RÉALISATION</span>
        <span class="btn-bottom">SUIVANTE</span>
      </a>
      {% else %}
      <span class="cta-button cta-small" aria-hidden="true">
        <span class="btn-top">RÉALISATION</span>
        <span class="btn-bottom">SUIVANTE</span>
      </span>
      {% endif %}
    </div>
  </div>
</div>